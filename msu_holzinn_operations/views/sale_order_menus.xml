<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- New Action for Admin Sales Orders -->
    <record id="action_admin_sales_orders" model="ir.actions.act_window">
        <field name="name">Admin Sales Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="context">{}</field>
        <field name="domain">[('has_work_order', '=', True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Sales Orders with active Work Orders found.
            </p>
        </field>
    </record>

    <!-- New Menu Item under Orders -->
    <menuitem id="menu_admin_sale_order"
              name="Admin Sales Orders"
              action="action_admin_sales_orders"
              parent="sale.sale_order_menu"
              sequence="3"/>

    <!-- Override Default Sales Orders Action to show CONFIRMED orders without Work Orders -->
    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="domain">[('state', '=', 'sale'), ('has_work_order', '=', False)]</field>
    </record>

    <!-- Override Default Quotations Action to show ONLY draft/sent/cancel without Work Orders -->
    <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
        <field name="domain">[('state', 'in', ['draft', 'sent', 'cancel']), ('has_work_order', '=', False)]</field>
    </record>
</odoo>
