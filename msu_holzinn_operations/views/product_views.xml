<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_price_history" model="ir.ui.view">
        <field name="name">product.template.form.price.history</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='standard_pri']" position="after">
                <field name="standard_price_date" readonly="1" class="oe_inline" force_save="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Price History">
                    <field name="price_history_ids" readonly="1" />
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_standard_price_history_tree" model="ir.ui.view">
        <field name="name">product.standard.price.history.tree</field>
        <field name="model">product.standard.price.history</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0">
                <field name="date"/>
                <field name="old_price"/>
                <field name="new_price"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>
</odoo>
