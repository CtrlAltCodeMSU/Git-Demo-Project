<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_msu_delivered" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.msu.delivered</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Injecting right underneath the custom partner_type radio buttons -->
            <xpath expr="//field[@name='partner_type']" position="after">
                <span class="d-inline-block ms-4">
                    <field name="project_delivered" nolabel="1"/>
                    <label for="project_delivered" string="Project Delivered"/>
                </span>
            </xpath>
        </field>
    </record>
</odoo>
